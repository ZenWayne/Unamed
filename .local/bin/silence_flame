#!/bin/bash
# silence_flame - Flameshot wrapper that saves to ~/Pictures and copies path to clipboard

# Generate filename with timestamp
FILENAME="$HOME/Pictures/silence_flame_$(date +%Y%m%d%H%M%S).png"

# Take screenshot with flameshot (GUI mode for selection)
flameshot gui -p "$FILENAME"

# Check if screenshot was saved (user might have cancelled)
if [ -f "$FILENAME" ]; then
    # Copy absolute path to clipboard using xsel
    echo -n "$FILENAME" | xsel -ib
    notify-send "Screenshot Saved" "Saved to: $FILENAME\nPath copied to clipboard" -i camera-photo
else
    notify-send "Screenshot Cancelled" "No screenshot was saved" -i dialog-warning
    exit 1
fi
